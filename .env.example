# LLM Provider Keys (Use either or both)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL / Supabase Connection URI
# Example: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/postgres

# LangSmith Observability Tracing (Optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=customer-support-agents
